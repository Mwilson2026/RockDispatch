# Supabase (safe to expose in browser — use publishable/anon key only, never sb_secret_)
# Copy to .env.local for Vite dev; add the same names in Vercel → Settings → Environment Variables
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Invite-only access (recommended): omit this or set false — only “Sign in” is shown; you create users in Supabase.
# For open self-registration (e.g. local dev), set: VITE_ALLOW_PUBLIC_SIGNUP=true
# VITE_ALLOW_PUBLIC_SIGNUP=

# Login uses usernames mapped to synthetic emails username@DOMAIN for Supabase. Must match the domain used when inviting users in the Supabase dashboard (default below).
# VITE_AUTH_EMAIL_DOMAIN=users.rockdispatch.local
